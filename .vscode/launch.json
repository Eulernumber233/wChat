{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AgentServer (uvicorn reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8200"
      ],
      "cwd": "${workspaceFolder}/wChat_AgentServer",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Pytest (AgentServer)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v"],
      "cwd": "${workspaceFolder}/wChat_AgentServer",
      "console": "integratedTerminal"
    }
  ]
}
