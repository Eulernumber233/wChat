[Server]
Host=0.0.0.0
Port=8200

[LLM]
Provider=deepseek
Model=deepseek-chat
BaseUrl=https://api.deepseek.com
; ApiKey prefer env DEEPSEEK_API_KEY; this key is fallback only
ApiKey=

[Agent]
MaxHistoryMessages=50
DefaultNumCandidates=3
EnableRelationshipSummary=true
EnableRAG=false
Temperature=0.7

[Backend]
; mock: use fixtures; grpc: call ChatServer (future)
Mode=mock
FixturePath=tests/fixtures/sample_chats.json

[RateLimit]
PerUserPerDay=100
